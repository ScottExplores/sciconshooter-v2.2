# Optional: point local dev at the deployed API instead of the local Vite middleware.
# VITE_LEADERBOARD_API_URL=https://your-deployment.vercel.app/api/leaderboard

# Recommended global leaderboard storage.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
SUPABASE_LEADERBOARD_TABLE=scicon_leaderboard
SUPABASE_MONTHLY_WINNERS_TABLE=scicon_monthly_winners

# Required for Vercel's protected monthly winner archive cron.
CRON_SECRET=make-a-long-random-secret

# Optional: send the archived monthly winner to Zapier/Make/Discord/etc.
# MONTHLY_WINNER_WEBHOOK_URL=
# MONTHLY_ALLOCATION_RSC=500

# Optional: enables the Reown / WalletConnect all-wallet modal in production.
# Local dev falls back to Reown's localhost-only demo project id.
# VITE_REOWN_PROJECT_ID=
# VITE_WALLETCONNECT_PROJECT_ID=
